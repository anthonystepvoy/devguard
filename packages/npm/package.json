{
  "name": "@anthonystepvoy/devguard",
  "version": "0.1.0",
  "description": "Experimental HOME/env isolation for package-manager install scripts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anthonystepvoy/devguard.git",
